# ============================================
# TeslaPulse Configuration
# ============================================
# Copy this file to .env.local and fill in your values:
#   cp .env.local.example .env.local
#
# Or skip this entirely — configure everything via the Settings page.

# ── Tesla Fleet API ──
# Get these from https://developer.tesla.com
TESLA_CLIENT_ID=
TESLA_CLIENT_SECRET=
TESLA_REDIRECT_URI=http://localhost:3000/auth/callback

# ── LLM Provider (pick one) ──
# Options: grok, claude, openai, gemini
LLM_PROVIDER=grok

# xAI Grok (default) — https://console.x.ai
XAI_API_KEY=

# Anthropic Claude — https://console.anthropic.com
ANTHROPIC_API_KEY=

# OpenAI GPT — https://platform.openai.com
OPENAI_API_KEY=

# Google Gemini — https://aistudio.google.com
GEMINI_API_KEY=

# ── Optional ──
# Mapbox token for custom map tiles — https://mapbox.com
NEXT_PUBLIC_MAPBOX_TOKEN=

# Domain for Tesla partner registration (production only)
TESLA_DOMAIN=
